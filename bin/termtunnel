#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Detect OS for process manager selection
case "$(uname)" in
  Darwin) OS="mac" ;;
  Linux)  OS="linux" ;;
  *)      echo "Unsupported OS: $(uname)" >&2; exit 1 ;;
esac

PLIST="$HOME/Library/LaunchAgents/com.termtunnel.server.plist"
SERVICE_ID="com.termtunnel.server"

usage() {
  echo "Usage: termtunnel <command>"
  echo ""
  echo "Commands:"
  echo "  start     Start the server"
  echo "  stop      Stop the server"
  echo "  restart   Restart the server"
  echo "  status    Show server status"
  echo "  logs      Tail server logs"
  echo "  url       Print the connection URL (Tailscale)"
  echo "  run       Run the server directly in the foreground"
}

case "${1:-}" in
  start)
    if [[ "$OS" == "mac" ]]; then
      launchctl load "$PLIST"
    else
      systemctl --user start termtunnel
    fi
    ;;
  stop)
    if [[ "$OS" == "mac" ]]; then
      launchctl unload "$PLIST"
    else
      systemctl --user stop termtunnel
    fi
    ;;
  restart)
    if [[ "$OS" == "mac" ]]; then
      launchctl kickstart -k "gui/$(id -u)/$SERVICE_ID"
    else
      systemctl --user restart termtunnel
    fi
    ;;
  status)
    if [[ "$OS" == "mac" ]]; then
      launchctl list "$SERVICE_ID" 2>/dev/null || echo "Service not loaded"
    else
      systemctl --user status termtunnel
    fi
    ;;
  logs)
    tail -f "$HOME/.termtunnel/server.log"
    ;;
  url)
    TS_BIN="$(which tailscale 2>/dev/null || echo "/Applications/Tailscale.app/Contents/MacOS/Tailscale")"
    TS_IP="$("$TS_BIN" ip -4 2>/dev/null || echo "tailscale-not-running")"
    PORT="$(cd "$PROJECT_DIR" && grep -E '^PORT=' .env 2>/dev/null | cut -d= -f2 || echo "3000")"
    echo "http://${TS_IP}:${PORT}"
    ;;
  run)
    cd "$PROJECT_DIR"
    exec node server.js
    ;;
  ""|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
